{
  "rewrites": [
    { "source": "/api/:path*", "destination": "https://idr-backend-production.up.railway.app/api/:path*" },
    { "source": "/scan", "destination": "/scan.html" },
    { "source": "/privacy", "destination": "/idrshield_legal.html" },
    { "source": "/terms", "destination": "/idrshield_legal.html" },
    { "source": "/thank-you", "destination": "/idrshield_thank_you.html" },
    { "source": "/admin", "destination": "/idrshield_admin.html" },
    { "source": "/verify/:domain*", "destination": "/idr_verify.html" },
    { "source": "/fix/:domain*", "destination": "/idrshield_fix.html" },
    { "source": "/badge", "destination": "/idrshield_badge.html" },
    { "source": "/login", "destination": "/idrshield_login.html" },
    { "source": "/portal", "destination": "/idrshield_portal.html" },
    { "source": "/support", "destination": "/idrshield_support.html" },
    { "source": "/registry", "destination": "/idrshield_registry.html" }
  ]
}
